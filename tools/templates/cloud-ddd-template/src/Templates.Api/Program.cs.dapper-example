// ============================================================================
// Key Differences from EF Core Setup
// ============================================================================
// 
// EF Core:
//   builder.Services.AddDbContext<ApplicationDbContext>(options =>
//       options.UseSqlServer(connectionString));
//
// Dapper:
//   builder.Services.AddDapperPersistence(builder.Configuration);
//
// Benefits:
//   - No DbContext overhead
//   - Connection pooling built-in
//   - Stored procedures for optimal performance
//   - Lower latency per request
//   - Support for 1000+ TPS
//
// Trade-offs:
//   - Must write SQL stored procedures manually
//   - No automatic migrations (use scripts instead)
//   - Requires SQL knowledge
//
// ============================================================================

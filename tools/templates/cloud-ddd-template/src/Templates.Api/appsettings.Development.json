{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Debug"
    }
  },
  "Features": {
    "Caching": {
      "Enabled": false
    },
    "Messaging": {
      "Enabled": false
    },
    "Cloud": {
      "Enabled": false
    }
  },
  "SharedCommon": {
    "Security": {
      "SecurityHeaders": {
        "Enabled": false,
        "StrictTransportSecurity": {
          "Enabled": false
        }
      },
      "RateLimit": {
        "Enabled": false
      },
      "InputValidation": {
        "Enabled": true
      },
      "Https": {
        "Enforced": false
      }
    },
    "Auth": {
      "Jwt": {
        "Enabled": false
      }
    },
    "Observability": {
      "SamplingRatio": 1.0,
      "OtlpEndpoint": null
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173", "http://localhost:4200" ],
    "AllowCredentials": true
  }
}
